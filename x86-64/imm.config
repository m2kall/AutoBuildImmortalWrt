# Target
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_BOARD="x86"
CONFIG_TARGET_SUBTARGET="64"

# Set the target profile to "generic"
CONFIG_TARGET_PROFILE="generic"

# Filesystem settings
# Force EXT4 and disable SquashFS
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_ROOTFS_PARTSIZE=1024 # Corresponds to the 1GB input, can be overridden
# Ensure SquashFS is disabled
# CONFIG_TARGET_ROOTFS_SQUASHFS is not set

# Image compression
CONFIG_TARGET_IMAGES_GZIP=y
